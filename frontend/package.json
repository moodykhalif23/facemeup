    "@react-navigation/native-stack": "^6.11.0",
    "@reduxjs/toolkit": "^2.5.0",
    "axios": "^1.8.4",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.1",
    "expo-camera": "~16.0.10",
    "expo-image-picker": "~16.0.5",
    "expo-notifications": "~0.30.0",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
